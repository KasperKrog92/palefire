{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Palefire",
  "version": "0.1.0",
  "identifier": "com.palefire.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Palefire",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#13161c"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
